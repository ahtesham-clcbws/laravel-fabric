{
    "name": "clcbws/laravel-fabric",
    "description": "High-fidelity, zero-dependency administrative scaffolding engine for the modern web.",
    "homepage": "https://github.com/ahtesham-clcbws/laravel-fabric",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "CLCBWS Team",
            "email": "support@clcbws.com"
        }
    ],
    "require": {
        "php": ">=8.3",
        "illuminate/support": "^13.0",
        "illuminate/console": "^13.0",
        "illuminate/database": "^13.0",
        "illuminate/view": "^13.0",
        "livewire/livewire": "^4.0"
    },
    "require-dev": {
        "orchestra/testbench": "^11.0",
        "pestphp/pest": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "CLCBWS\\Fabric\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "CLCBWS\\Fabric\\FabricServiceProvider"
            ],
            "aliases": {
                "Fabric": "CLCBWS\\Fabric\\Facades\\Fabric"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
