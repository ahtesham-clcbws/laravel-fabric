it('can search across {{ MODEL_NAME }} records', function () {
    {{ MODEL_NAME }}::factory()->create(['{{ SEARCH_COL }}' => 'UNIQUE_FABRIC_STRING']);
    {{ MODEL_NAME }}::factory()->create(['{{ SEARCH_COL }}' => 'OTHER_STRING']);

    Livewire::test({{ MODEL_NAME }}Table::class)
        ->set('search', 'UNIQUE_FABRIC_STRING')
        ->assertSee('UNIQUE_FABRIC_STRING')
        ->assertDontSee('OTHER_STRING');
});

it('can render the {{ MODEL_NAME }} editor modal', function () {
    Livewire::test({{ MODEL_NAME }}Editor::class)
        ->assertStatus(200)
        ->assertSee('Save {{ MODEL_NAME }}');
});

it('can create a new {{ MODEL_NAME }} record', function () {
    $data = [
        {{ SAMPLE_DATA }}
    ];

    Livewire::test({{ MODEL_NAME }}Editor::class)
        ->set('form', $data)
        ->call('save')
        ->assertHasNoErrors()
        ->assertDispatched('closeModal');

    expect({{ MODEL_NAME }}::count())->toBe(1);
});

