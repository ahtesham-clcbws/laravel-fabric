<div class="flex justify-center" x-data="{ rotateX: 0, rotateY: 0 }">
        <div 
            @mousemove="rotateX = (20 - ($event.clientY - $el.getBoundingClientRect().top) / $el.clientHeight * 40); rotateY = (($event.clientX - $el.getBoundingClientRect().left) / $el.clientWidth * 40 - 20)"
            @mouseleave="rotateX = 0; rotateY = 0"
            class="relative w-80 h-96 bg-neutral-900 rounded-[40px] transition-transform duration-200 ease-out preserve-3d shadow-2xl"
            :style="'transform: perspective(1000px) rotateX(' + rotateX + 'deg) rotateY(' + rotateY + 'deg)'"
        >
            <div class="absolute inset-0 p-10 flex flex-col justify-end overflow-hidden rounded-[40px]">