<div class="max-w-2xl mx-auto py-32 px-4 text-center">
    <div class="inline-flex size-20 rounded-[32px] bg-neutral-900 items-center justify-center text-white text-3xl font-black mb-12 dark:bg-white dark:text-neutral-900 shadow-2xl">F</div>
    <h1 class="text-6xl font-black text-neutral-800 dark:text-white tracking-tighter uppercase italic leading-none mb-8">Minimal Forge</h1>
