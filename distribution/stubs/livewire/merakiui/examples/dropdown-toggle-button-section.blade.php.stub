<button @click="isOpen = !isOpen" class="relative z-10 flex items-center p-2 text-sm text-neutral-600 bg-white border border-transparent rounded-xl focus:border-{{ PRIMARY_BASE }}-500 focus:ring-opacity-40 dark:focus:ring-opacity-40 focus:ring-{{ PRIMARY_BASE }}-300 dark:focus:ring-{{ PRIMARY_BASE }}-400 focus:ring dark:text-white dark:bg-neutral-800 focus:outline-none">
            <span class="mx-1">Jane Doe</span>
            <svg class="w-5 h-5 mx-1" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 15.713L18.01 9.70299L16.597 8.28799L12 12.888L7.40399 8.28799L5.98999 9.70199L12 15.713Z" fill="currentColor"></path>
            </svg>
        </button>