<div>
        <label for="domain name" class="block text-sm text-neutral-500 dark:text-neutral-300">Domain Name</label>

        <div class="flex items-center mt-2">
            <p class="py-2.5 px-3 text-neutral-500 bg-neutral-100 dark:bg-neutral-800 dark:border-neutral-700 border border-r-0 rtl:rounded-r-lg rtl:rounded-l-none rtl:border-l-0 rtl:border-r rounded-l-lg">http://</p>
            <input type="text" placeholder="merakiui.com" class="block w-full rounded-l-none rtl:rounded-l-lg rtl:rounded-r-none placeholder-neutral-400/70 dark:placeholder-neutral-500 rounded-2xl border border-neutral-200 bg-white px-5 py-2.5 text-neutral-700 focus:border-{{ PRIMARY_BASE }}-400 focus:outline-none focus:ring focus:ring-{{ PRIMARY_BASE }}-300 focus:ring-opacity-40 dark:border-neutral-600 dark:bg-neutral-900 dark:text-neutral-300 dark:focus:border-{{ PRIMARY_BASE }}-300" />
        </div>
    </div>