<div class="relative">
        <input type="email" id="floating-email" class="peer p-4 block w-full bg-neutral-50 border-transparent rounded-2xl text-sm placeholder:text-transparent focus:border-{{ PRIMARY }} focus:ring-{{ PRIMARY }} focus:pt-6 focus:pb-2 [&:not(:placeholder-shown)]:pt-6 [&:not(:placeholder-shown)]:pb-2 dark:bg-neutral-800 dark:border-transparent dark:text-neutral-400 dark:focus:ring-neutral-600 transition-all" placeholder="name@example.com">
        <label for="floating-email" class="absolute top-0 start-0 p-4 h-full text-sm font-bold text-neutral-500 truncate pointer-events-none transition ease-in-out duration-100 peer-focus:text-xs peer-focus:-translate-y-1.5 peer-focus:text-{{ PRIMARY }} peer-[:not(:placeholder-shown)]:text-xs peer-[:not(:placeholder-shown)]:-translate-y-1.5 peer-[:not(:placeholder-shown)]:text-neutral-400">Email Address</label>
    </div>