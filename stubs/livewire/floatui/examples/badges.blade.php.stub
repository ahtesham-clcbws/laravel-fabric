<div class="flex flex-wrap items-center justify-center gap-4">
    <span class="px-5 py-1.5 bg-neutral-900 text-white rounded-lg text-[10px] font-black uppercase tracking-widest italic">Core Cluster</span>
    <span class="px-5 py-1.5 bg-{{ PRIMARY }}/10 text-{{ PRIMARY }} border border-{{ PRIMARY }}/20 rounded-lg text-[10px] font-black uppercase tracking-widest">Orchestrator</span>
    <span class="px-5 py-1.5 bg-emerald-500/10 text-emerald-500 border border-emerald-500/20 rounded-lg text-[10px] font-black uppercase tracking-widest">Active</span>
</div>
