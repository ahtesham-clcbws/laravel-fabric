<section class="py-14">
            <div class="max-w-screen-xl mx-auto px-4 md:px-8">
                <ul class="flex flex-col items-center justify-center gap-x-12 gap-y-10 sm:flex-row sm:flex-wrap md:gap-x-24">
                    {
                        stats.map((item, idx) => (
                            <li key={idx} class="text-center">
                                <h4 class="text-4xl text-neutral-800 font-semibold">{item.data}</h4>
                                <p class="mt-3 text-neutral-600 font-medium">{item.title}</p>
                            </li>