                <div class="size-10 rounded-xl bg-neutral-50 dark:bg-neutral-950 border-4 border-white dark:border-neutral-900"></div>
            </template>
        </div>
        <button class="text-[10px] font-black text-{{ PRIMARY }} uppercase tracking-widest hover:underline italic">Configure ➔</button>
    </div>
</div>
