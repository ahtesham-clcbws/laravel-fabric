<div class="relative">
        <label class="block mb-2 text-xs font-black text-neutral-400 uppercase tracking-widest italic px-1">Registry ID</label>
        <input 
            type="text" 
            placeholder="e.g. CORE-ALPHA" 
            class="w-full px-5 py-4 text-sm text-neutral-800 bg-white border border-neutral-100 rounded-2xl focus:border-{{ PRIMARY }} focus:ring-4 focus:ring-{{ PRIMARY }}/10 outline-none transition-all dark:bg-neutral-900 dark:border-neutral-800 dark:text-white"
        >
    </div>