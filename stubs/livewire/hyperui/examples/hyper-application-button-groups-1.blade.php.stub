<!doctype html>
<html lang="en" class="dark font-sans antialiased">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link href="/component.css" rel="stylesheet" />
    <script src="/component.js" defer></script>
  </head>
  <body class="flex justify-center p-6">
    <div class="inline-flex">
      <button
        class="rounded-s-sm border border-neutral-200 px-3 py-2 font-medium text-neutral-700 transition-colors hover:bg-neutral-50 hover:text-neutral-900 focus:z-10 focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 focus:ring-offset-white focus:outline-none disabled:pointer-events-auto disabled:opacity-50"
      >
        View
      </button>

      <button
        class="-ms-px border border-neutral-200 px-3 py-2 font-medium text-neutral-700 transition-colors hover:bg-neutral-50 hover:text-neutral-900 focus:z-10 focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 focus:ring-offset-white focus:outline-none disabled:pointer-events-auto disabled:opacity-50"
      >
        Edit
      </button>

      <button
        class="-ms-px rounded-e-sm border border-neutral-200 px-3 py-2 font-medium text-neutral-700 transition-colors hover:bg-neutral-50 hover:text-neutral-900 focus:z-10 focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 focus:ring-offset-white focus:outline-none disabled:pointer-events-auto disabled:opacity-50"
      >
        Delete
      </button>
    </div>
  </body>
</html>