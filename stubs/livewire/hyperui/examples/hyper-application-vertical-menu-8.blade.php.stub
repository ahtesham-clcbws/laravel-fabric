<!doctype html>
<html lang="en" class="dark font-sans antialiased">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link href="/component.css" rel="stylesheet" />
    <script src="/component.js" defer></script>
  </head>
  <body class="mx-auto max-w-sm p-6">
    <div class="flow-root">
      <ul class="-my-2 divide-y divide-neutral-100">
        <li class="py-2">
          <ul class="space-y-1">
            <li>
              <a
                href="#"
                class="block rounded-2xl bg-neutral-100 px-4 py-2 text-sm font-medium text-neutral-700"
              >
                Profile
              </a>
            </li>

            <li>
              <a
                href="#"
                class="block rounded-2xl px-4 py-2 text-sm font-medium text-neutral-500 hover:bg-neutral-100 hover:text-neutral-700"
              >
                Team
              </a>
            </li>

            <li>
              <a
                href="#"
                class="block rounded-2xl px-4 py-2 text-sm font-medium text-neutral-500 hover:bg-neutral-100 hover:text-neutral-700"
              >
                Projects
              </a>
            </li>

            <li>
              <a
                href="#"
                class="block rounded-2xl px-4 py-2 text-sm font-medium text-neutral-500 hover:bg-neutral-100 hover:text-neutral-700"
              >
                Meetings
              </a>
            </li>

            <li>
              <a
                href="#"
                class="block rounded-2xl px-4 py-2 text-sm font-medium text-neutral-500 hover:bg-neutral-100 hover:text-neutral-700"
              >
                Calendar
              </a>
            </li>
          </ul>
        </li>

        <li class="py-2">
          <ul class="space-y-1">
            <li>
              <a
                href="#"
                class="block rounded-2xl px-4 py-2 text-sm font-medium text-neutral-500 hover:bg-neutral-100 hover:text-neutral-700"
              >
                Update
              </a>
            </li>

            <li>
              <a
                href="#"
                class="block rounded-2xl px-4 py-2 text-sm font-medium text-neutral-500 hover:bg-neutral-100 hover:text-neutral-700"
              >
                Help
              </a>
            </li>

            <li>
              <a
                href="#"
                class="block rounded-2xl px-4 py-2 text-sm font-medium text-neutral-500 hover:bg-neutral-100 hover:text-neutral-700"
              >
                Settings
              </a>
            </li>
          </ul>
        </li>

        <li class="py-2">
          <form action="#">
            <button
              type="submit"
              class="block w-full rounded-2xl px-4 py-2 [text-align:_inherit] text-sm font-medium text-neutral-500 hover:bg-neutral-100 hover:text-neutral-700"
            >
              Logout
            </button>
          </form>
        </li>
      </ul>
    </div>
  </body>
</html>