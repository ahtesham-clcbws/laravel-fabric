<!doctype html>
<html lang="en" class="dark font-sans antialiased">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link href="/component.css" rel="stylesheet" />
    <script src="/component.js" defer></script>
  </head>
  <body class="p-6">
    <form
      action="#"
      class="mx-auto max-w-md space-y-4 rounded-2xl border border-neutral-300 bg-neutral-100 p-6"
    >
      <div>
        <label class="block text-sm font-medium text-neutral-900" for="name">Name</label>

        <input
          class="mt-1 w-full rounded-2xl border-neutral-300 focus:border-{{ PRIMARY_BASE }}-500 focus:outline-none"
          id="name"
          type="text"
          placeholder="Your name"
        />
      </div>

      <div>
        <label class="block text-sm font-medium text-neutral-900" for="email">Email</label>

        <input
          class="mt-1 w-full rounded-2xl border-neutral-300 focus:border-{{ PRIMARY_BASE }}-500 focus:outline-none"
          id="email"
          type="email"
          placeholder="Your email"
        />
      </div>

      <div>
        <label class="block text-sm font-medium text-neutral-900" for="subject">Subject</label>

        <select
          class="mt-1 w-full rounded-2xl border-neutral-300 focus:border-{{ PRIMARY_BASE }}-500 focus:outline-none"
          id="subject"
        >
          <option value="">Select a subject</option>
          <option value="general-inquiry">General Inquiry</option>
          <option value="support">Support</option>
          <option value="feedback">Feedback</option>
        </select>
      </div>

      <div>
        <label class="block text-sm font-medium text-neutral-900" for="priority">Priority</label>

        <select
          class="mt-1 w-full rounded-2xl border-neutral-300 focus:border-{{ PRIMARY_BASE }}-500 focus:outline-none"
          id="priority"
        >
          <option value="">Select a priority</option>
          <option value="low">Low</option>
          <option value="medium">Medium</option>
          <option value="high">High</option>
        </select>
      </div>

      <div>
        <label class="block text-sm font-medium text-neutral-900" for="message">Message</label>

        <textarea
          class="mt-1 w-full resize-none rounded-2xl border-neutral-300 focus:border-{{ PRIMARY_BASE }}-500 focus:outline-none"
          id="message"
          rows="4"
          placeholder="Your message"
        ></textarea>
      </div>

      <button
        class="block w-full rounded-2xl border border-{{ PRIMARY_BASE }}-600 bg-{{ PRIMARY_BASE }}-600 px-12 py-3 text-sm font-medium text-white transition-colors hover:bg-transparent hover:text-{{ PRIMARY_BASE }}-600"
        type="submit"
      >
        Send Message
      </button>
    </form>
  </body>
</html>