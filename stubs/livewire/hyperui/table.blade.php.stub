<div class="rounded-lg border border-gray-200 bg-white">
  <div class="p-6 flex items-center justify-between">
    <div>
      <h3 class="text-lg font-bold text-gray-900">{{ MODEL_PLURAL }}</h3>
      <p class="mt-1 text-sm text-gray-500">A detailed list of all {{ MODEL_PLURAL }} in the system.</p>
