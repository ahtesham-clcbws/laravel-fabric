      </thead>

      <tbody class="divide-y divide-gray-200">
        @forelse($rows as $row)
          <tr class="hover:bg-gray-50/50">
            <td class="whitespace-nowrap px-4 py-2">
              <input type="checkbox" value="{{ $row->id }}" wire:model.live="selected" class="size-4 rounded border-gray-300">
            </td>
            {{-- Loop through columns --}}
            @foreach(array_keys($row->getAttributes()) as $attr)
                 <td class="whitespace-nowrap px-4 py-2 text-gray-700">{{ $row->$attr }}</td>
            @endforeach
            <td class="whitespace-nowrap px-4 py-2 text-right">
              <button wire:click="$dispatch('openModal', { component: '{{ VIEW_PATH }}.editor', arguments: { record: {{ $row->id }} } })" class="inline-block rounded bg-indigo-100 px-4 py-2 text-xs font-medium text-{{ PRIMARY }} hover:bg-indigo-200">
                Edit
              </button>
            </td>
          </tr>
        @empty
          <tr>
            <td colspan="100%" class="px-4 py-8 text-center text-gray-500 italic">No entries found.</td>
          </tr>
        @endforelse
      </tbody>
    </table>
  </div>

  <div class="p-4 border-t border-gray-200">
    {{ $rows->links() }}
  </div>
</div>
