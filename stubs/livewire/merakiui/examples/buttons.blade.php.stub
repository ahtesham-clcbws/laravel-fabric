<div class="flex flex-wrap gap-8 items-center justify-center py-20 px-10">
    <button class="px-12 py-5 bg-neutral-900 text-white rounded-2xl text-[10px] font-black uppercase tracking-widest shadow-2xl hover:bg-{{ PRIMARY }} transition-all italic">Provision Node</button>
    <button class="px-12 py-5 border-4 border-neutral-50 text-neutral-800 rounded-2xl text-[10px] font-black uppercase tracking-widest hover:border-{{ PRIMARY }} transition-all dark:text-white dark:border-neutral-900 italic">Audit Registry</button>
    <button class="flex items-center gap-6 px-10 py-5 bg-{{ PRIMARY }} text-white rounded-3xl text-[10px] font-black uppercase tracking-widest shadow-xl shadow-{{ PRIMARY }}/20 hover:scale-105 transition-all italic">
        <span>Cluster Sync</span>
        <svg class="size-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M13 10V3L4 14h7v7l9-11h-7z" stroke-width="3"/></svg>
    </button>
</div>
