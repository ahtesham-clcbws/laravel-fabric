<div>
        <label for="email" class="block text-sm text-neutral-500 dark:text-neutral-300">Email Address</label>

        <input type="email" placeholder="john@example.com" class="mt-2 block w-full placeholder-neutral-400/70 rounded-2xl border border-neutral-200 bg-white px-5 py-2.5 text-neutral-700 focus:border-{{ PRIMARY_BASE }}-400 focus:outline-none focus:ring focus:ring-{{ PRIMARY_BASE }}-300 focus:ring-opacity-40 dark:border-neutral-600 dark:bg-neutral-900 dark:text-neutral-300 dark:focus:border-{{ PRIMARY_BASE }}-300" />
        
        <p class="mt-3 text-xs text-neutral-400 dark:text-neutral-600">Lorem ipsum dolor sit amet consectetur adipisicing elit.</p>
    </div>