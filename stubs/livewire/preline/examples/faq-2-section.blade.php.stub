<div class="rounded-3xl border border-neutral-100 bg-white dark:border-neutral-800 dark:bg-neutral-900 transition-all duration-300 shadow-sm" :class="active === 2 ? 'shadow-xl border-{{ PRIMARY }}/30' : ''">
                <button 
                    @click="active === 2 ? active = null : active = 2"
                    class="w-full flex items-center justify-between p-6 text-start focus:outline-none"
                >
                    <h4 class="text-lg font-black text-neutral-800 dark:text-white tracking-tight">How does the zero-dependency rule work?</h4>
                    <span 
                        class="shrink-0 size-8 flex items-center justify-center rounded-xl bg-neutral-50 text-neutral-400 dark:bg-neutral-800 transition-transform duration-500"
                        :class="active === 2 ? 'rotate-180 bg-{{ PRIMARY }}/10 text-{{ PRIMARY }}' : ''"
                    >
                        <svg xmlns="http://www.w3.org/2000/svg" class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                        </svg>
                    </span>
                </button>
                <div x-show="active === 2" x-collapse x-cloak>
                    <div class="px-6 pb-6 pt-0">
                        <p class="text-sm text-neutral-500 dark:text-neutral-400 leading-relaxed font-medium">
                            Every component harvested by Fabric is converted to use native Alpine.js for interactivity. We remove all third-party JavaScript bundles (like preline.js or flowbite.js) to ensure your application remains lightweight, fast, and easy to maintain.
                        </p>
                    </div>
                </div>
            </div>