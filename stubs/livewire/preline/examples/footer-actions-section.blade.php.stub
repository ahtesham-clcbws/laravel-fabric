<div class="p-8 sm:p-12 bg-neutral-50/50 dark:bg-neutral-900/50 flex justify-end gap-4">
                    <button type="button" class="py-3 px-8 bg-neutral-200 text-neutral-800 rounded-2xl text-[10px] font-black uppercase tracking-widest hover:bg-neutral-300 transition-all dark:bg-neutral-800 dark:text-white">Discard</button>
                    <button type="submit" class="py-3 px-10 bg-{{ PRIMARY }} text-white rounded-2xl text-[10px] font-black uppercase tracking-widest shadow-xl shadow-{{ PRIMARY }}/20 hover:bg-{{ PRIMARY }}/90 transition-all">Save Manifest</button>
                </div>
            </form>
        </div>
    </div>
