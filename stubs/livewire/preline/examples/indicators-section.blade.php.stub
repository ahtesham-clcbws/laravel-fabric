<div class="absolute bottom-6 left-1/2 -translate-x-1/2 flex gap-x-2 z-10">
        <template x-for="(i, index) in count" :key="index">
            <button 
                @click="active = index"
                class="size-2 rounded-full transition-all duration-300"
                :class="active === index ? 'w-8 bg-{{ PRIMARY }}' : 'bg-white/50 hover:bg-white'"
            ></button>
        </template>
    </div>
</div>