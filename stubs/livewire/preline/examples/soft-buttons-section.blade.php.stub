<div class="space-y-4">
        <h4 class="text-[10px] font-black text-neutral-400 uppercase tracking-[0.2em]">Soft Variants</h4>
        <div class="flex flex-wrap gap-4 items-center">
            <button type="button" class="py-3 px-4 inline-flex items-center gap-x-2 text-sm font-bold rounded-2xl bg-{{ PRIMARY }}/10 text-{{ PRIMARY }} hover:bg-{{ PRIMARY }}/20 transition-all">Primary</button>
            <button type="button" class="py-3 px-4 inline-flex items-center gap-x-2 text-sm font-bold rounded-2xl bg-neutral-100 text-neutral-800 hover:bg-neutral-200 dark:bg-neutral-800 dark:text-neutral-200 transition-all">Neutral</button>
            <button type="button" class="py-3 px-4 inline-flex items-center gap-x-2 text-sm font-bold rounded-2xl bg-teal-100 text-teal-600 hover:bg-teal-200 dark:bg-teal-500/10 dark:text-teal-400 transition-all">Success</button>
        </div>
    </div>