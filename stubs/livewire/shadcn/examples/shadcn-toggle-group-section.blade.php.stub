<div class="inline-flex p-1 bg-neutral-100 rounded-md dark:bg-neutral-900" x-data="{ selected: ['bold'] }">
        <template x-for="val in ['bold', 'italic', 'underline']">
            <button 
                @click="selected.includes(val) ? selected = selected.filter(v => v !== val) : selected.push(val)"
                class="px-3 py-1.5 rounded-sm text-xs font-bold transition-all"
                :class="selected.includes(val) ? 'bg-white shadow-sm text-neutral-900 dark:bg-neutral-950 dark:text-white' : 'text-neutral-500 hover:text-neutral-900 dark:hover:text-neutral-400'"
                x-text="val.charAt(0).toUpperCase() + val.slice(1)"
            ></button>
        </template>
    </div>