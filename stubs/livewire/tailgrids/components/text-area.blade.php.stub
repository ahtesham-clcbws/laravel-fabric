<div class="space-y-3">
    <label class="text-[10px] font-black text-neutral-400 uppercase tracking-[0.3em] px-1 italic">Manifest Description</label>
    <textarea 
        rows="6"
        placeholder="Enter orchestration details..." 
        class="w-full px-8 py-6 rounded-[32px] bg-white border-2 border-neutral-100 focus:border-{{ PRIMARY }} focus:shadow-2xl focus:shadow-{{ PRIMARY }}/10 outline-none text-sm font-bold transition-all dark:bg-neutral-900 dark:border-neutral-800 dark:text-white"
    ></textarea>
</div>
