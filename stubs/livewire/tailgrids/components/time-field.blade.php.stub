<div class="space-y-3 max-w-xs mx-auto">
    <label class="text-[10px] font-black text-neutral-400 uppercase tracking-[0.3em] px-1 italic">Sync Time</label>
    <div class="relative">
        <input 
            type="time" 
            class="w-full px-8 py-5 rounded-[24px] bg-white border-2 border-neutral-100 focus:border-{{ PRIMARY }} outline-none text-sm font-black uppercase tracking-widest transition-all dark:bg-neutral-900 dark:border-neutral-800 dark:text-white"
        >
    </div>
</div>
